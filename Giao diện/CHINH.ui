   <string notr="true">
QMainWindow{
    background:#f5f7fb;
}

QFrame{
    background:white;
    border:1px solid #e5e7eb;
    border-radius:10px;
}

QPushButton{
    background:white;
    color:#374151;
    border:1px solid #d1d5db;
    border-radius:8px;
    padding:8px;
    font-weight:600;
}

QPushButton:hover{
    background:#eff6ff;
    border:1px solid #60a5fa;
}

QPushButton:pressed{
    background:#dbeafe;
}

QLineEdit,QComboBox{
    background:white;
    border:1px solid #d1d5db;
    border-radius:8px;
    padding:6px;
}

QTreeView,QTableView{
    background:white;
    border:1px solid #d1d5db;
    alternate-background-color:#f8fafc;
}

QHeaderView::section{
    background:#2563eb;
    color:white;
    border:none;
    padding:6px;
    font-weight:bold;
}

QTabBar::tab{
    background:#eef2ff;
    padding:8px 16px;
    border-top-left-radius:8px;
    border-top-right-radius:8px;
}

QTabBar::tab:selected{
    background:white;
    border-bottom:2px solid #2563eb;
}
</string>
