   <string notr="true">QWidget{
    background-color: #f5f7fa;
    font-family: Segoe UI;
    font-size: 10pt;
}

QPushButton{
    background-color: #4A90E2;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 8px 15px;
    font-weight: bold;
}

QPushButton:hover{
    background-color: #357ABD;
}

QPushButton:pressed{
    background-color: #2D5F99;
}

QLineEdit{
    background-color: white;
    border: 2px solid #dcdfe6;
    border-radius: 8px;
    padding: 8px;
}

QLineEdit:focus{
    border: 2px solid #4A90E2;
}

QComboBox{
    background-color: white;
    border: 2px solid #dcdfe6;
    border-radius: 8px;
    padding: 6px;
}

QComboBox:hover{
    border: 2px solid #4A90E2;
}

QListWidget{
    background-color: white;
    border: 2px solid #dcdfe6;
    border-radius: 10px;
}

QListWidget::item{
    padding: 8px;
}

QListWidget::item:selected{
    background-color: #4A90E2;
    color: white;
}

QGroupBox{
    border: 2px solid #dcdfe6;
    border-radius: 10px;
    margin-top: 12px;
    font-weight: bold;
    background-color: white;
}

QGroupBox::title{
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px;
}</string>
